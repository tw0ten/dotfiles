@theme "default"

* {
	background: rgba(16, 16, 16, 100%);
	foreground: rgba(255, 255, 255, 100%);

	active-foreground: rgba(64, 224, 208, 100%);
	active-background: var(background);
	selected-active-background: var(active-foreground);

	alternate-active-foreground: var(active-foreground);
	alternate-active-background: var(active-background);

	lightfg: var(foreground);
	lightbg: var(background);

	spacing: 0;
	border-radius: 2px;
}
window {
	width: 30%;
	border: 0;
	padding: 0.5em;
	border-radius: 0.5em;
}
mainbox {
	border-radius: 0;
}

listview {
	padding: 0;
	spacing: 0.25em;
	border: 0;
	border-radius: 0;
}
element {
	padding: 0 0.25em;
	spacing: 0.5em;
}

overlay {
	padding: 0;
	margin: 0;
}

inputbar {
	padding: 0;
	margin: 0 0 0.25em 0;
	border-radius: 0;
}
prompt {
	enabled: false;
	text-color: var(active-foreground);
}
textbox-prompt-colon {
	enabled: false;
}
entry {
	placeholder:"";
	border-radius: 0;
}
num-filtered-rows {
	text-color: var(foreground);
}
textbox-num-sep {
	text-color: var(foreground);
}
num-rows {
	text-color: var(foreground);
}

message {
	margin: 0.25em 0;
	padding: 0;
	border: 0;
}

scrollbar {
	handle-width: 0.75em;
	border-radius: 0;
}

button {
	margin: 0.25em 0 0 0;
}
