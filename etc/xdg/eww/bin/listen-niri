#!/bin/sh
niri msg -j event-stream |
	while read -r _; do
		workspaces="$(niri msg -j workspaces | jq -rc 'sort_by(.idx) | map(select(.output == "eDP-1"))')"
		keyboard_layouts="$(niri msg -j keyboard-layouts)"
		windows='{}'
		focused_window="$(niri msg -j focused-window)"
		#windows="$(niri msg -j windows | jq -rc 'sort_by(.layout.pos_in_scrolling_layout[0])')"
		casts="$(niri msg -j casts)"
		printf '{%s}\n' "\"workspaces\":$workspaces,\"keyboard-layouts\":$keyboard_layouts,\"windows\":$windows,\"focused-window\":$focused_window,\"casts\":$casts"
	done
