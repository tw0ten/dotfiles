#!/bin/sh
set -e

[ -e "$1" ] || {
	tput rev
	exec echo 'no such file'
}

file="$(file -bL "$1")"

tput setaf 2
echo "$file" | fold -s -w "$2"
tput sgr0 | sed 's/(B//'

[ -d "$1" ] && {
	echo
	[ -r "$1" ] || {
		tput rev
		exec echo 'permission denied'
	}
	[ "$(find -L "$1" -maxdepth 1 | wc -l)" = 1 ] && {
		tput rev
		exec echo 'empty'
	}

	cd "$1"
	command -v tree >/dev/null && {
		tree . -L 2 -F -C --noreport --dirsfirst --compress -2 | tail -n +2 | sed 's/..//'
	} || ls -1 -F --color --group-directories-first
	exit
}

mime="$(file -bL --mime-type "$1")"

echo "$mime $(xdg-mime query default "$mime")"
echo

case "$mime" in
'image'/*) jp2a --width="$2" --colors "$1" ;;
*) false ;;
esac && exit

[ -f "$1" ] && grep -Iq . "$1" && {
	set -- "$1" '' $(($3 - 3))
	# #todo technically not -3 cuz | fold

	wcl="$(cat "$1" | wc -l)"
	[ $((wcl)) -le "$3" ] && exec cat "$1"

	head -n $(($3 / 2)) "$1"
	tput rev
	echo "$((wcl - $3 + 1))l"
	tput sgr0 | sed 's/(B//'
	tail -n $(($3 / 2 - (($3 + 1) % 2))) "$1"

	exit
}

tput rev
[ -s "$1" ] || exec echo 'empty'
[ -r "$1" ] || exec echo 'permission denied'
echo 'binary'
