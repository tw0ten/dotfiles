#!/bin/sh
set -u
lock='hyprlock'

pkill -0 "^${lock}$" && exit

mute="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q ' \[MUTED\]$' && echo true || echo false)"
keyboard="$(niri msg -j keyboard-layouts | jq '.current_idx')"

wpctl set-mute @DEFAULT_AUDIO_SINK@ 1
niri msg action switch-layout 0

"$lock" &
niri msg action focus-workspace 0
wait

"$mute" || wpctl set-mute @DEFAULT_AUDIO_SINK@ 0
niri msg action switch-layout "$keyboard"
