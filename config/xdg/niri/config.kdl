layout {
	empty-workspace-above-first

	gaps 2

	struts {
		left 2
		right 2
		bottom -2
	}

	border {
		off
		width 2
	}

	focus-ring {
		off
		width 2
	}

	tab-indicator {
		place-within-column
		width 2
		gap 1
	}
}

overview {
	zoom 0.5

	workspace-shadow { off; }
}

include "rules.kdl"

include "animations.kdl"
include "colors.kdl"

include "binds.kdl"

include "input.kdl"

include "env.kdl"
