#!/bin/sh
set -e

second=1
minute=$((second * 60))
hour=$((minute * 60))
day=$((hour * 24))

offset=$(python -c 'import time; print(-time.timezone)')

write_hm(){( set -- $(cat); echo $(($1 / hour)) $(($1 % hour / minute)); )}


i_waketime=$((6 * hour + 30 * minute))
i_sleeptime=$((8 * hour + 30 * minute))


o_bedtime=$((day + i_waketime - i_sleeptime))
while true; do
	epoch=$EPOCHSECONDS
	now=$(((epoch + offset) % day))
	o_sleeptime=$(set -- $((now)) $((i_waketime)) $((day)) && [ $1 -lt $2 ] && echo $(($2 - $1)) || echo $(($3 - $1 + $2)))

	{ date --date "@$((epoch + i_sleeptime))" +'%w' | grep "[60]" -q; } && {
		sleep $((1 * hour)) && continue
	} || true

	[ $((o_sleeptime)) -lt $((i_sleeptime + (1 * hour))) ] && notify-send \
		"bedtime: $(printf '%02i/%02i' $(echo $o_bedtime | write_hm))" \
		"sleeptime left: $(printf '%i/%02i' $(echo $o_sleeptime | write_hm))" \
		-t $((1000 * minute / 2))

	sleep $((5 * minute))
done
