#!/bin/sh
set -eu
i() { exec "$@"; }
[ ! "$XDG_SESSION_TYPE" = 'tty' ] && [ "$TERM" = 'linux' ] && i() { exec "$TERMINAL" -e "$@"; }

for i; do (
	[ -e "$i" ] && {
		[ -d "$i" ] && i "$FILES" "$i"

		[ -f "$i" ] &&
			{ grep -Iq . "$i" || [ ! -s "$i" ]; } &&
			case "$(file -bL --mime-type "$i")" in
			'inode'/'x-empty' | 'application'/* | 'text'/*) i "$VISUAL" "$i" ;;
			esac || true
	}

	exec xdg-open "$i"
); done
