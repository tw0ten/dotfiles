#!/bin/sh
set -e
i() { exec "$@"; }
[ "$TERM" = 'linux' ] && i() { exec "$TERMINAL" -e "$@"; }

for i; do (
	[ -e "$i" ] && {
		[ -d "$i" ] && i "$FILES" "$i"
		[ -f "$i" ] && grep -Iq . "$i" &&
			case "$(xdg-mime query filetype "$i")" in
			'inode'/'x-empty' | 'application'/* | 'text'/*) i "$VISUAL" "$i" ;;
			esac || true
	}

	exec xdg-open "$i"
); done
