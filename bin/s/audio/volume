#!/bin/sh
set -e

i="${1:-$(printf " \n%s\n%s\n%s" '0.05-' "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | sed 's/.*: //')" '0.05+' | dmenu -p "volume " -l 4 -a 2)}"

case "$i" in
' ') wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
*)
	wpctl set-volume @DEFAULT_AUDIO_SINK@ "$i"
	wpctl set-mute @DEFAULT_AUDIO_SINK@ 0
	;;
esac
