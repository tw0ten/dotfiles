#!/usr/bin/env sh
set -e

. 'lib/sh/profile'

(
	cd etc

	i() {
		set -- "$PWD/$1" "$2"
		mkdir -p "$(dirname "$2")"
		ln -vsfT "$1" "$2"
	}

	(
		cd xdg
		for f in *; do
			i "$f" "$XDG_CONFIG_HOME/$f"
		done
	)

	(
		cd home

		i bash/profile ~/.bash_profile
		i bash/rc ~/.bashrc
		i inputrc ~/.inputrc
		i ssh/config ~/.ssh/config
	)

	[ "$(id -u)" = 0 ] || exit

	i() {
		mkdir -p "$(dirname "$2")"
		cp -vrT "$1" "$2"
	}

	(
		cd root

		i ssh/ /etc/ssh
		i sudoers.d/ /etc/sudoers.d
		i sysctl.d/ /etc/sysctl.d
		i ly/ /etc/ly
		i postfix/ /etc/postfix

		i pacman.conf /etc/pacman.conf

		i locale /usr/share/i18n/locales/custom
	)
) || true

[ "$PLATFORM" = 'unknown' ] || . "run/$PLATFORM"

git init
