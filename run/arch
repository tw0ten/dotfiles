#!/bin/sh

( sudo pacman -Syu
	AUR_HELPER=paru
	i() { $AUR_HELPER -S "$@" || true; }
	command -v $AUR_HELPER || ( cd "$(mktemp -d)"; git clone "https://aur.archlinux.org/$AUR_HELPER" .; makepkg -si )

	i neovim lf \
		openssh qbittorrent-nox nginx ufw \
		btop fastfetch ripgrep ly nix tmux ffmpeg
	i niri pipewire nvidia-open \
		mako swww rofi quickshell fcitx5 \
		firefox alacritty \
		mpv torbrowser-launcher libreoffice-still gimp obs-studio blender kdenlive \
		noto-fonts noto-fonts-emoji noto-fonts-cjk
echo )

( set -ex; cd etc; i() { sudo "$@"; }
	systemctl --user enable brightness.timer

	i systemctl disable getty@tty1
	i systemctl enable ly@tty1

	i cp -rTL ../config/etc/grub/theme /boot/grub/themes/default
	i grub-mkconfig -o /boot/grub/grub.cfg

	i ufw reset
	i ufw default deny incoming
	i ufw default allow outgoing
	i ufw allow ssh
	i ufw enable
	i ufw reload

	gsettings set 'org.gnome.desktop.interface' font-name "$(fc-match sans-serif -f '%{family} %{size}')"
	gsettings set 'org.gnome.desktop.interface' color-scheme 'prefer-dark'
echo )
