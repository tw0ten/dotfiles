#!/bin/sh

(
	set +e
	sudo pacman -Syu

	AUR_HELPER=paru
	command -v "$AUR_HELPER" || (
		set -e
		cd "$(mktemp -d)"
		git clone "https://aur.archlinux.org/$AUR_HELPER" .
		makepkg -si
	)

	i() { "$AUR_HELPER" -S "$@"; }

	i neovim lf \
		openssh qbittorrent-nox ufw \
		ly nix \
		btop fastfetch tmux
	i niri alacritty firefox \
		mako awww eww rofi \
		noto-fonts noto-fonts-emoji noto-fonts-cjk

	true
)

(
	set -x

	ln -vsfT "$PWD/share/icons/" "$HOME/.local/share/icons/custom"

	[ "$(id -u)" = 0 ]

	systemctl disable getty@tty1 && systemctl enable ly@tty1

	ufw reset
	ufw default deny incoming
	ufw default allow outgoing
	ufw allow ssh
	ufw enable

	systemctl enable \
		sshd \
		qbittorrent-nox
)
