#!/bin/sh
set -eu
volume="${1:-1.0}"
target="${2:-default_sink}"

cd "$DOTFILES/share/snd/morse"

mkdir -p o
[ -e 'o/sleep' ] || ffmpeg -f lavfi -i "sine=frequency=0:duration=0.05" -f wav -y -- 'o/sleep'
[ -e 'o/dot' ] || ffmpeg -f lavfi -i "sine=frequency=1000:duration=0.05" -f wav -y -- 'o/dot'
[ -e 'o/dash' ] || ffmpeg -f lavfi -i "sine=frequency=1000:duration=0.15" -f wav -y -- 'o/dash'

i="$(cat | fold -w1)"

play() { pw-play --volume="$volume" --target="$target" -- "$@"; }
_sleep() { play 'o/sleep'; }
dot() { play 'o/dot' && _sleep; }
dash() { play 'o/dash' && _sleep; }

IFS='
'
for c in $i; do
	case "$c" in
	'a')
		dot
		dash
		;;
	'b')
		dash
		dot
		dot
		dot
		;;
	'c')
		dash
		dot
		dash
		dot
		;;
	'd')
		dash
		dot
		dot
		;;
	'e')
		dot
		;;
	'f')
		dot
		dot
		dash
		dot
		;;
	'g')
		dash
		dot
		dot
		;;
	'h')
