		dot
		dash
		;;
	'v')
		dot
		dot
		dot
		dash
		;;
	'w')
		dot
		dash
		dash
		;;
	'x')
		dash
		dot
		dot
		dash
		;;
	'y')
		dash
		dot
		dash
		dash
		;;
	'z')
		dash
		dash
		dot
		dot
		;;
	'1')
		dot
		dash
		dash
		dash
		dash
		;;
	'2')
