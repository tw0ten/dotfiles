#!/bin/sh
set -eu

icon="$PWD/.io/icon.png"

cd "$1"

[ -e '.m/read' ] && exit
i="$(basename "$PWD")"
echo 'notify' "$i"

o="$(
	body="$(
		printf '%s\n' \
			"$(date --date="@$(($(cat '.m/date')))" +%c)" \
			"$(cat -- '-from' || echo '?') > $(cat -- '-to' || echo '?')" \
			'' \
			"$(cat '#subject' || echo "$i")"
	)"

	exec notify-send \
		-A 'ignore=mark read' \
		-A 'default=open' \
		-t $((60 * 1000)) \
		-i "$icon" \
		-- 'mail' "$body"
)"

case "$o" in
'ignore') ;;
'default') "$TERMINAL" -e "$FILES" '#body' ;;
'') exit ;;
*) false ;;
esac

date +%s >'.m/read'
