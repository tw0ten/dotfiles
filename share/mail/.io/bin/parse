#!/bin/python
import sys
import os
from email import policy
from email.parser import BytesParser
from email.utils import parsedate_to_datetime


[source, target] = sys.argv[1:]

os.mkdir(target)
os.mkdir(f"{target}/.m")
i = BytesParser(policy=policy.default).parse(open(source, "rb"))


def write(i, v):
    open(f"{target}/{i}", "w").write(v)


write("#subject", i["subject"])
write("-from", i["from"])
write("-to", i["to"])
write(".m/date", f"{int(parsedate_to_datetime(i["date"]).timestamp())}")

path = f"{target}/attachments"
os.mkdir(path)
for v in i.iter_attachments():
    open(f"{path}/{v.get_filename()}", "wb").write(v.get_payload(decode=True))

f = 2
try:
    write("#body", i.get_body(preferencelist=("plain", "html",)).get_content())
except Exception:
    f = f - 1
try:
    write("#body.html", i.get_body(preferencelist=("html",)).get_content())
except Exception:
    f = f - 1
assert f > 0
